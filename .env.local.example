# Copy to .env.local and fill in values.

# -----------------------------------------------------------------------------
# Clerk (https://clerk.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZGVhci1jb3JhbC05OC5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=whsec_xxxx

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com)
# Anon key is safe for client (browser). Service role key must NEVER be
# exposed to the client — use only in API routes and server code.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# -----------------------------------------------------------------------------
# Anthropic (https://anthropic.com)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxx

# -----------------------------------------------------------------------------
# Stripe (https://stripe.com)
# Pro $9/mo, Business $29/mo — create products and prices in Dashboard.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_PRICE_ID=price_xxxx
STRIPE_BUSINESS_PRICE_ID=price_xxxx

# -----------------------------------------------------------------------------
# Resend (https://resend.com) — transactional emails
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=FixMyDoc <onboarding@yourdomain.com>

# -----------------------------------------------------------------------------
# Upstash Redis (https://upstash.com) — rate limiting for /api/analyze & /api/upload
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# -----------------------------------------------------------------------------
# App URL (for redirects and links in emails)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
